{
  "expo": {
    "name": "WalkingAtlas",
    "slug": "walkingatlas",
    "scheme": "walkingatlas",
    "version": "0.1.0",
    "runtimeVersion": "0.1.0",
    "newArchEnabled": true,
    "orientation": "portrait",
    "ios": {
      "bundleIdentifier": "com.walkingatlas.app",
      "infoPlist": {
        "UIBackgroundModes": [
          "location"
        ],
        "NSLocationWhenInUseUsageDescription": "WalkingAtlas uses your precise location to unlock the tiles you visit while you walk.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "WalkingAtlas keeps unlocking tiles during an active Walk when your phone is locked."
      }
    },
    "plugins": [
      "expo-location",
      "expo-sqlite",
      "@maplibre/maplibre-react-native",
      "./plugins/withQuotedReactNativeBundleScript",
      "expo-router"
    ],
    "android": {
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "package": "com.walkingatlas.app"
    }
  }
}
